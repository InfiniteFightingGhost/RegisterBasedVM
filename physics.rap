DEFINE epochs 100000
DEFINE i r8
LOADC r1 0.0
LOADC r2 10.0
LOADC r3 2.5
LOADC r4 0.0
LOADC r5 9.81
LOADC r6 0.016
LOADC r7 0.0
loop:
    MUL r9 r5 r6
    SUB r4 r4 r9
    MUL r10 r3 r6
    ADD r1 r1 r10
    MUL r11 r4 r6
    ADD r2 r2 r11
    LT 0 r2 r7
    JUMP skip_ground
    MOVE r2 r7
    LOADC r4 0.0
skip_ground:
    FOR i epochs 1 < loop
HALT
